PORT=3000
MONGO_URI=mongodb://127.0.0.1:27017/encurtador
JWT_SECRET=troque-este-segredo
JWT_EXPIRES_IN=1d
FRONTEND_URL=http://localhost:4200
ADMIN_EMAIL=admin@encurtador.local
# Prefira hash bcrypt. Exemplo gerado com Node/bcrypt.
ADMIN_PASSWORD_HASH=
# Compatibilidade temporária apenas para bootstrap inicial do admin.
ADMIN_PASSWORD=
# TTL do cache em memória de slugs (ms). Padrão: 60000 (1 min)
SLUG_CACHE_TTL_MS=60000
# Máximo de entradas no cache (FIFO). Padrão: 20000 (~20 MB)
SLUG_CACHE_MAX_SIZE=20000
